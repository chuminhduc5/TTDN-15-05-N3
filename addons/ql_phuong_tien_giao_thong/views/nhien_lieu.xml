<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_nhien_lieu_form" model="ir.ui.view">
            <field name="name">nhien_lieu</field>
            <field name="model">nhien_lieu</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_read_only" style="font-size:25px">Nhiên liệu</div>
                        <group col="4" string="Thông tin chung">
                            <field name="ma_phuong_tien"/>
                            <field name="luong_tieu_hao_nhien_lieu"/>
                            <field name="thoi_gian_cap_nhat"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_nhien_lieu_tree" model="ir.ui.view">
            <field name="name">nhien_lieu</field>
            <field name="model">nhien_lieu</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="ma_phuong_tien"/>
                    <field name="luong_tieu_hao_nhien_lieu"/>
                    <field name="thoi_gian_cap_nhat"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="nhien_lieu_search">
            <field name="model">nhien_lieu</field>
            <field name="arch" type="xml">
                <search>
                    <field name="ma_phuong_tien"/>
                    <field name="luong_tieu_hao_nhien_lieu"/>
                    <field name="thoi_gian_cap_nhat"/>
                </search>
            </field>
        </record>

        <record id="action_nhien_lieu" model="ir.actions.act_window">
            <field name="name">Nhiên liệu</field>
            <field name="res_model">nhien_lieu</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="nhien_lieu_search"/>
        </record>
    </data>
</odoo>