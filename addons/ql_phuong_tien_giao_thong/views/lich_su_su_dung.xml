<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_lich_su_su_dung_form" model="ir.ui.view">
            <field name="name">lich_su_su_dung</field>
            <field name="model">lich_su_su_dung</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_read_only" style="font-size:25px">Lịch sử sử dụng</div>
                        <group col="4" string="Thông tin chung">
                            <field name="ma_phieu_muon_xe"/>
                            <field name="ma_nv_noi_bo"/>
                            <field name="ma_phuong_tien"/>
                            <field name="trang_thai"/>
                            <field name="thoi_gian_muon_xe"/>
                            <field name="thoi_gian_tra_xe"/>
                            <field name="mo_ta"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_lich_su_su_dung_tree" model="ir.ui.view">
            <field name="name">lich_su_su_dung</field>
            <field name="model">lich_su_su_dung</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="ma_phieu_muon_xe"/>
                    <field name="ma_nv_noi_bo"/>
                    <field name="ma_phuong_tien"/>
                    <field name="trang_thai"/>
                    <field name="thoi_gian_muon_xe"/>
                    <field name="thoi_gian_tra_xe"/>
                    <field name="mo_ta"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="lich_su_su_dung_search">
            <field name="model">lich_su_su_dung</field>
            <field name="arch" type="xml">
                <search>
                    <field name="ma_phieu_muon_xe"/>
                    <field name="ma_nv_noi_bo"/>
                    <field name="ma_phuong_tien"/>
                    <field name="trang_thai"/>
                    <field name="thoi_gian_muon_xe"/>
                    <field name="thoi_gian_tra_xe"/>
<!--                    <searchpanel>-->
<!--                        <field name="ma_phieu_muon_xe" filter="1"/>-->
<!--                        <field name="ma_nv_noi_bo" filter="1"/>-->
<!--                        <field name="ma_phuong_tien" filter="1"/>-->
<!--                    </searchpanel>-->
                </search>
            </field>
        </record>

        <record id="action_lich_su_su_dung" model="ir.actions.act_window">
            <field name="name">Lịch sử sử dụng</field>
            <field name="res_model">lich_su_su_dung</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="lich_su_su_dung_search"/>
        </record>
    </data>
</odoo>