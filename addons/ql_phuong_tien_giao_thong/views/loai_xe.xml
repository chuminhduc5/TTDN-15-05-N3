<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_loai_xe_form" model="ir.ui.view">
            <field name="name">loai_xe</field>
            <field name="model">loai_xe</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_read_only" style="font-size:25px">Loại xe</div>
                        <group col="4" string="Thông tin chung">
                            <field name="ten_loai_xe"/>
                        </group>
                        <group col="4" string="Thông tin phương tiện">
                            <field name="tong_so_luong" readonly="1"/>
                            <field name="so_luong_san_sang" readonly="1"/>
                            <field name="so_luong_dang_hoat_dong" readonly="1"/>
                            <field name="so_luong_bao_tri" readonly="1"/>
                        </group>
                        <group>
                            <field name="ma_phuong_tien" nolabel="1">
                                <tree editable="bottom">
                                    <field name="ma_phuong_tien"/>
                                    <field name="ten_phuong_tien"/>
                                    <field name="bien_so"/>
                                    <field name="trang_thai"/>
                                </tree>
                            </field>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_loai_xe_tree" model="ir.ui.view">
            <field name="name">loai_xe</field>
            <field name="model">loai_xe</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="ten_loai_xe"/>
                    <field name="tong_so_luong"/>
                    <field name="so_luong_san_sang"/>
                    <field name="so_luong_dang_hoat_dong"/>
                    <field name="so_luong_bao_tri"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="loai_xe_search">
            <field name="model">loai_xe</field>
            <field name="arch" type="xml">
                <search>
                    <field name="ten_loai_xe"/>
                    <field name="tong_so_luong"/>
                    <field name="so_luong_san_sang"/>
                    <field name="so_luong_dang_hoat_dong"/>
                    <field name="so_luong_bao_tri"/>
                </search>
            </field>
        </record>

        <record id="action_loai_xe" model="ir.actions.act_window">
            <field name="name">Loại xe</field>
            <field name="res_model">loai_xe</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="loai_xe_search"/>
        </record>
<!--        <menuitem id="menu_loai_xe" name="Loại xe" action="action_loai_xe" parent="base.menu_base"/>-->
    </data>
</odoo>